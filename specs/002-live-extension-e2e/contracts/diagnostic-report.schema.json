{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "diagnostic-report.schema.json",
  "title": "Whiskey Empire West Live E2E Report",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "startedAt",
    "finishedAt",
    "targetUrl",
    "platform",
    "outcome",
    "lastSuccessfulStage",
    "firstFailedStage",
    "browser",
    "extension",
    "stages",
    "observations",
    "errors",
    "cleanup"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "type": "string", "minLength": 1, "maxLength": 100 },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "targetUrl": { "const": "https://thewestsideblono.com/drink/drink-menu/" },
    "platform": { "const": "darwin" },
    "outcome": { "enum": ["passed", "failed", "blocked"] },
    "lastSuccessfulStage": {
      "oneOf": [
        { "$ref": "#/$defs/stageName" },
        { "type": "null" }
      ]
    },
    "firstFailedStage": {
      "oneOf": [
        { "$ref": "#/$defs/stageName" },
        { "type": "null" }
      ]
    },
    "browser": {
      "oneOf": [
        { "$ref": "#/$defs/browserIdentity" },
        { "type": "null" }
      ]
    },
    "extension": {
      "oneOf": [
        { "$ref": "#/$defs/extensionIdentity" },
        { "type": "null" }
      ]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/testStage" }
    },
    "observations": { "$ref": "#/$defs/observations" },
    "errors": {
      "type": "array",
      "maxItems": 20,
      "items": { "$ref": "#/$defs/diagnosticError" }
    },
    "cleanup": { "$ref": "#/$defs/cleanupOutcome" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "outcome": { "const": "passed" } },
        "required": ["outcome"]
      },
      "then": {
        "properties": {
          "lastSuccessfulStage": { "const": "cleanup" },
          "firstFailedStage": { "const": null },
          "browser": { "$ref": "#/$defs/browserIdentity" },
          "extension": { "$ref": "#/$defs/extensionIdentity" },
          "cleanup": {
            "allOf": [
              { "$ref": "#/$defs/cleanupOutcome" },
              {
                "properties": {
                  "browserClosed": { "const": true },
                  "profileRemoved": { "const": true }
                }
              }
            ]
          },
          "observations": {
            "allOf": [
              { "$ref": "#/$defs/observations" },
              {
                "properties": {
                  "unexpectedHarnessRequests": { "const": 0 },
                  "panel": {
                    "allOf": [
                      { "$ref": "#/$defs/panelObservation" },
                      {
                        "properties": {
                          "resultCount": { "type": "integer", "minimum": 1 },
                          "filteredCount": { "type": "integer", "minimum": 1 },
                          "selectedSort": { "const": "price-desc" },
                          "ariaSort": { "const": "descending" }
                        }
                      }
                    ]
                  }
                }
              }
            ]
          }
        }
      },
      "else": {
        "properties": {
          "firstFailedStage": { "$ref": "#/$defs/stageName" }
        }
      }
    }
  ],
  "$defs": {
    "stageName": {
      "enum": [
        "prerequisites",
        "build-identity",
        "browser-launch",
        "extension-availability",
        "live-page",
        "whiskey-tab",
        "action-popup",
        "scan-start",
        "scan-completion",
        "search-assertion",
        "sort-assertion",
        "cleanup"
      ]
    },
    "testStage": {
      "type": "object",
      "required": ["name", "status", "startedAt", "finishedAt", "deadlineMs", "summary"],
      "properties": {
        "name": { "$ref": "#/$defs/stageName" },
        "status": { "enum": ["pending", "running", "passed", "failed", "blocked", "skipped"] },
        "startedAt": { "type": ["string", "null"], "format": "date-time" },
        "finishedAt": { "type": ["string", "null"], "format": "date-time" },
        "deadlineMs": { "type": "integer", "minimum": 1, "maximum": 120000 },
        "summary": { "type": "string", "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "browserIdentity": {
      "type": "object",
      "required": ["provider", "browserName", "version", "headless", "profileId"],
      "properties": {
        "provider": { "const": "playwright" },
        "browserName": { "const": "chromium" },
        "version": { "type": "string", "minLength": 1, "maxLength": 100 },
        "headless": { "type": "boolean" },
        "profileId": { "type": "string", "minLength": 1, "maxLength": 100 }
      },
      "additionalProperties": false
    },
    "extensionIdentity": {
      "type": "object",
      "required": ["id", "name", "version", "manifestVersion", "permissions", "hostPermissions", "buildDigest"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-p]{32}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 200 },
        "version": { "type": "string", "minLength": 1, "maxLength": 50 },
        "manifestVersion": { "const": 3 },
        "permissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "hostPermissions": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "buildDigest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "whiskeyTabObservation": {
      "type": "object",
      "required": ["accessibleName", "role", "frameOrigin", "selected", "advertisedTotal"],
      "properties": {
        "accessibleName": { "type": "string", "maxLength": 200 },
        "role": { "type": "string", "maxLength": 100 },
        "frameOrigin": { "type": "string", "maxLength": 500 },
        "selected": { "type": "boolean" },
        "advertisedTotal": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "popupObservation": {
      "type": "object",
      "required": ["origin", "scanLabel", "scanEnabled", "acknowledged", "statusText"],
      "properties": {
        "origin": { "type": "string", "pattern": "^chrome-extension://[a-p]{32}$" },
        "scanLabel": { "type": "string", "maxLength": 200 },
        "scanEnabled": { "type": "boolean" },
        "acknowledged": { "type": "boolean" },
        "statusText": { "type": "string", "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "panelObservation": {
      "type": "object",
      "required": ["present", "finalStatus", "resultCount", "searchQueryLength", "filteredCount", "selectedSort", "ariaSort"],
      "properties": {
        "present": { "type": "boolean" },
        "finalStatus": { "type": "string", "maxLength": 500 },
        "resultCount": { "type": ["integer", "null"], "minimum": 0 },
        "searchQueryLength": { "type": ["integer", "null"], "minimum": 0 },
        "filteredCount": { "type": ["integer", "null"], "minimum": 0 },
        "selectedSort": { "type": ["string", "null"], "maxLength": 100 },
        "ariaSort": { "type": ["string", "null"], "maxLength": 100 }
      },
      "additionalProperties": false
    },
    "visibleElement": {
      "type": "object",
      "required": ["tag", "role", "accessibleName", "state"],
      "properties": {
        "tag": { "type": "string", "maxLength": 50 },
        "role": { "type": ["string", "null"], "maxLength": 100 },
        "accessibleName": { "type": "string", "maxLength": 200 },
        "state": { "type": "object", "maxProperties": 10 }
      },
      "additionalProperties": false
    },
    "observations": {
      "type": "object",
      "required": [
        "currentUrl",
        "pageTitle",
        "frameOrigins",
        "documentRequestOrigins",
        "directHarnessRequestCount",
        "unexpectedHarnessRequests",
        "whiskeyTab",
        "popup",
        "panel",
        "visibleElements"
      ],
      "properties": {
        "currentUrl": { "type": ["string", "null"], "maxLength": 2000 },
        "pageTitle": { "type": ["string", "null"], "maxLength": 500 },
        "frameOrigins": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 500 }
        },
        "documentRequestOrigins": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "maxLength": 500 }
        },
        "directHarnessRequestCount": { "type": "integer", "minimum": 0 },
        "unexpectedHarnessRequests": { "type": "integer", "minimum": 0 },
        "whiskeyTab": {
          "oneOf": [
            { "$ref": "#/$defs/whiskeyTabObservation" },
            { "type": "null" }
          ]
        },
        "popup": {
          "oneOf": [
            { "$ref": "#/$defs/popupObservation" },
            { "type": "null" }
          ]
        },
        "panel": {
          "oneOf": [
            { "$ref": "#/$defs/panelObservation" },
            { "type": "null" }
          ]
        },
        "visibleElements": {
          "type": "array",
          "maxItems": 50,
          "items": { "$ref": "#/$defs/visibleElement" }
        }
      },
      "additionalProperties": false
    },
    "diagnosticError": {
      "type": "object",
      "required": ["source", "stage", "message", "urlOrigin"],
      "properties": {
        "source": { "enum": ["runner", "browser", "page", "popup", "network"] },
        "stage": { "$ref": "#/$defs/stageName" },
        "message": { "type": "string", "maxLength": 1000 },
        "urlOrigin": { "type": ["string", "null"], "maxLength": 500 }
      },
      "additionalProperties": false
    },
    "cleanupOutcome": {
      "type": "object",
      "required": ["browserClosed", "profileRemoved", "finishedAt", "message"],
      "properties": {
        "browserClosed": { "type": "boolean" },
        "profileRemoved": { "type": "boolean" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "message": { "type": "string", "maxLength": 500 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
